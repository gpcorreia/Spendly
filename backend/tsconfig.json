{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "app.ts",
    "src/server.ts",
    "src/config/**/*.ts",
    "src/controllers/**/*.ts",
    "src/routes/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
